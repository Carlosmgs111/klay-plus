---
import ClientRouter from "astro/components/ClientRouter.astro";
import "../styles/global.css";
interface Props {
  title?: string;
}

const { title = "klay+" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="light dark" />
    <title>{title} — klay+</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link
      href="https://cdn.boxicons.com/3.0.3/fonts/basic/boxicons.min.css"
      rel="stylesheet"
    />
    <ClientRouter />
  </head>
  <body class="bg-surface-0">
    <!-- Mesh gradient background -->
    <div class="fixed inset-0 pointer-events-none overflow-hidden" aria-hidden="true">
      <!-- Primary blue wash — top-left anchor -->
      <div class="absolute -top-[20%] -left-[10%] w-[70%] h-[60%] rounded-full opacity-[0.18] dark:opacity-[0.12] blur-[120px] bg-blue-500"></div>
      <!-- Secondary cool accent — top-right -->
      <div class="absolute -top-[10%] right-[5%] w-[50%] h-[50%] rounded-full opacity-[0.12] dark:opacity-[0.08] blur-[100px] bg-sky-400"></div>
      <!-- Warm counterpoint — bottom-right -->
      <div class="absolute bottom-[0%] right-[10%] w-[55%] h-[45%] rounded-full opacity-[0.10] dark:opacity-[0.07] blur-[110px] bg-indigo-500"></div>
      <!-- Subtle center fill -->
      <div class="absolute top-[30%] left-[25%] w-[50%] h-[40%] rounded-full opacity-[0.06] dark:opacity-[0.05] blur-[100px] bg-blue-300"></div>
    </div>
    <!-- Subtle grid overlay -->
    <div class="fixed inset-0 pointer-events-none opacity-[0.12]" aria-hidden="true">
      <div
        class="absolute inset-0 bg-[linear-gradient(rgba(59,130,246,0.08)_1px,transparent_1px),linear-gradient(90deg,rgba(59,130,246,0.08)_1px,transparent_1px)] bg-[length:32px_32px]"
      ></div>
    </div>
    <slot />
  </body>
</html>

<script is:inline>
  (function () {
    try {
      var stored = localStorage.getItem("klay-theme");
      var prefersDark = window.matchMedia(
        "(prefers-color-scheme: dark)"
      ).matches;
      var isDark = stored === "dark" || (stored !== "light" && prefersDark);
      if (isDark) {
        document.documentElement.classList.add("dark");
        document.documentElement.style.colorScheme = "dark";
      } else {
        document.documentElement.style.colorScheme = "light";
      }
    } catch (e) {}
  })();
</script>
